# Backend - Gestion de Stock y Ventas

# Puerto del servidor
PORT=3001

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=usuario_mysql
DB_PASSWORD=contraseña_segura
DB_NAME=gestion_stock

# CORS: origenes permitidos (separados por coma)
# Ej: http://localhost:5173,https://midominio.v2networks.cl
FRONTEND_ORIGINS=http://localhost:5173

# JWT
JWT_SECRET=cambiar_por_una_cadena_aleatoria_larga
JWT_EXPIRES_IN=3h

# Bcrypt
BCRYPT_ROUNDS=10

# Body limit
BODY_LIMIT=1mb
